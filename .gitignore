# Große Dateien - liegen auf Disk, nicht in Git
_anhaenge/
!_anhaenge/.gitkeep
!_anhaenge/**/.gitkeep

# Obsidian Workspace-State (lokal)
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Plugin-Configs und Templates bleiben im Git
!.obsidian/templates/
!.obsidian/plugins/
!.obsidian/snippets/

# API-Ordner: kompletter Inhalt ignorieren, ausser Template und Doku
_api/*
!_api/.gitkeep
!_api/.env.example
!_api/*.md

# Secrets / API Keys (Defense-in-Depth, falls .env-Files anderswo landen)
_secrets/
.env
.env.local
.env.*.local
*.env
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node
node_modules/
npm-debug.log*

# Generierte API-JSONs werden über _api/* ignoriert (siehe oben)

# Claude Code Session-Artefakte
.claude/worktrees/

# Obsidian Trash
.trash/

# Temp
*.tmp
*.bak
~*

# Google Drive Upload-Cache
.tmp.driveupload/

# Source-Exports nicht committen (zu gro├ƒ)
00-eingang/claude/*.json
00-eingang/notion/

# Syncthing-Internals (per-device, nicht im Git)
.stfolder/
.stversions/

# Obsidian volatile state (graph layout pro Session)
.obsidian/graph.json

# PDF-Preview Tempfolder
.tmp_pdf_preview/
